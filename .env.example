# Vandura — Environment Variables
# Copy to .env and fill in your values

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Slack
SLACK_APP_TOKEN=xapp-...
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C0123ABCDEF

# Database
DATABASE_URL=postgres://vandura:vandura@localhost:5432/vandura

# KMS (local | gcp-kms | vault)
KMS_PROVIDER=local
KMS_LOCAL_KEY_FILE=.dev-master-key
# KMS_KEY_URI=gcp-kms://projects/.../keyRings/.../cryptoKeys/...

# Object Storage (S3-compatible — MinIO for dev, GCS/S3 for prod)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=vandura
S3_SECRET_KEY=vandura123
S3_BUCKET=vandura-results
S3_REGION=us-east-1
S3_SIGNED_URL_EXPIRY=86400
# For GCS: use S3-compatible endpoint https://storage.googleapis.com
# For AWS S3: remove S3_ENDPOINT

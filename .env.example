# Vandura — Environment Variables
# Copy to .env and fill in your values

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Slack
SLACK_APP_TOKEN=xapp-...
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C0123ABCDEF

# Slack User Token (E2E testing — posts as real user to trigger @mentions)
SLACK_USER_TOKEN=xoxp-...

# Database (app metadata — tasks, users, approvals, audit log)
DATABASE_URL=postgres://vandura:vandura@localhost:5432/vandura

# Target database for the agent's db_query tool (the data the agent queries)
DB_TOOL_CONNECTION_URL=postgres://vandura:vandura@localhost:5432/sampledb

# KMS (local | gcp-kms | vault)
KMS_PROVIDER=local
KMS_LOCAL_KEY_FILE=.dev-master-key
# KMS_KEY_URI=gcp-kms://projects/.../keyRings/.../cryptoKeys/...

# Object Storage (S3-compatible — MinIO for dev, GCS/S3 for prod)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=vandura
S3_SECRET_KEY=vandura123
S3_BUCKET=vandura-results
S3_REGION=us-east-1
S3_SIGNED_URL_EXPIRY=86400
# For GCS: use S3-compatible endpoint https://storage.googleapis.com
# For AWS S3: remove S3_ENDPOINT

# Grafana (MCP server for dashboard/metrics access)
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=glsa_...

# Vandura Memory (persistent knowledge store)
VANDURA_MEMORY_DIR=/home/vandura/.vandura/memory

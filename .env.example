# Vandura — Environment Variables
# Copy to .env and fill in your values

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Slack
SLACK_APP_TOKEN=xapp-...
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C0123ABCDEF

# Database
DATABASE_URL=postgres://vandura:vandura@localhost:5432/vandura

# KMS (local | gcp-kms | vault)
KMS_PROVIDER=local
KMS_LOCAL_KEY_FILE=.dev-master-key
# KMS_KEY_URI=gcp-kms://projects/.../keyRings/.../cryptoKeys/...

# GCS (local | gcs)
GCS_PROVIDER=local
GCS_LOCAL_PATH=./tmp/uploads
# GCS_BUCKET=your-org-vandura-results
# GCS_SERVICE_ACCOUNT_KEY_FILE=./gcs-sa-key.json

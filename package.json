  },
  "homepage": "https://github.com/barockok/vandura#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@aws-sdk/client-s3": "^3.1002.0",
    "@aws-sdk/s3-request-presigner": "^3.1002.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@slack/bolt": "^4.6.0",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0",
    "slackify-markdown": "^5.0.0",
    "uuid": "^13.0.0",
